  "constraints": {
    "drc_spacing": {
      "default_gap_nm": 700,
      "default_gap_source": "PLACE_GAP_1T = max(2*DEV_MARGIN+M2_SIG_W, MIN_VIA_CC) = max(700,690) = 700",
      "hbt_gap_nm": 1200,
      "hbt_gap_source": "HBT_MARGIN(500) + DEV_MARGIN(200) + M2_SIG_W(300) = 1000, rounded for CntB.h1",
      "hbt_halo_um": 2.0,
      "hbt_halo_note": "Substrate contact ring reservation around HBT devices (ptap ring or mixed ring)"
    },
    "well_aware_spacing": {
      "nwell_islands": [
        {
          "id": "NWell_A",
          "net": "vdd_vco",
          "devices": [
            "M1",
            "M2",
            "M3",
            "M5",
            "MPu1",
            "MPu2",
            "MPu3",
            "MPu4",
            "MPu5"
          ]
        },
        {
          "id": "NWell_B",
          "net": "vdd",
          "devices": [
            "MBp1",
            "MBp2"
          ]
        }
      ],
      "inter_island_min_nm": 1800,
      "inter_island_rule": "NW.b1 (different-net NWell spacing)",
      "intra_island_min_nm": 0,
      "intra_island_note": "Same-net NWells can merge (gap=0), but watch nBuLay threshold",
      "nbulay_threshold_nm": 2990,
      "nbulay_note": "Merged NWell width >= 2990nm triggers nBuLay generation -> NBL.c=3200nm spacing",
      "design_intent": "NWell_A/B separated to preserve VDD_VCO/VDD RC filtering (Riso+Cdec)",
      "bridge_policy": {
        "NWell_A_NWell_B": "isolate",
        "reason": "Different supply domains (vdd_vco vs vdd), Riso filtering requires isolation",
        "intra_island": "merge",
        "intra_note": "Same-island devices share NWell (e.g. mirror+vco_pu in NWell_A can merge)"
      }
    },
    "tie_reservation": {
      "pmos_ntap": {
        "applies_to": [
          "pmos_mirror",
          "pmos_vco",
          "pmos_buf1",
          "pmos_buf2"
        ],
        "tie_type": "ntap",
        "keepout_w_nm": 1120,
        "keepout_h_nm": 1120,
        "max_distance_nm": 20000,
        "max_distance_rule": "LU.a",
        "placement": "above_device",
        "note": "ntap NWell must be same-net as device NWell (merge or bridge)"
      },
      "nmos_ptap": {
        "applies_to": [
          "nmos_vco",
          "nmos_bias",
          "nmos_diode",
          "nmos_buf1",
          "nmos_buf2"
        ],
        "tie_type": "ptap",
        "keepout_w_nm": 1000,
        "keepout_h_nm": 1000,
        "max_distance_nm": 20000,
        "max_distance_rule": "LU.b",
        "placement": "below_device"
      },
      "strategy": "row_strip",
      "strategy_note": "Each device row shares a tie strip, more area-efficient than per-device ties"
    },
    "matching": {
      "match_groups": [
        {
          "devices": [
            "M1",
            "M2",
            "M3",
            "M5"
          ],
          "type": "same_row_equal_spacing",
          "reason": "PMOS current mirror: VGS matching requires identical environment"
        },
        {
          "devices": [
            "MPu1",
            "MPu2",
            "MPu3",
            "MPu4",
            "MPu5"
          ],
          "type": "same_row_equal_spacing",
          "reason": "VCO PMOS ring: symmetry for phase noise"
        },
        {
          "devices": [
            "MPd1",
            "MPd2",
            "MPd3",
            "MPd4",
            "MPd5"
          ],
          "type": "same_row_equal_spacing",
          "reason": "VCO NMOS ring: symmetry for phase noise"
        },
        {
          "devices": [
            "MNb1",
            "MNb2",
            "MNb3",
            "MNb4",
            "MNb5"
          ],
          "type": "same_row_equal_spacing",
          "reason": "VCO bias array: uniform bias current"
        }
      ],
      "symmetry": [],
      "keep_close": [
        {
          "devices": [
            "Q1",
            "Rptat"
          ],
          "max_distance_um": 25.0,
          "reason": "net_rptat (Q2.E -> Rptat.PLUS): minimize parasitic R"
        },
        {
          "devices": [
            "MNdiode",
            "MNb1"
          ],
          "max_distance_um": 15.0,
          "reason": "nmos_bias net: MNdiode sets bias for all MNb, minimize IR drop"
        }
      ]
    },
