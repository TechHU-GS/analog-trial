    "activ": {"w": 640, "h": 640},
    "nwell": {"w": 1120, "h": 1120},
    "m1_pad": {"w": 640, "h": 640},
    "contacts": {"count": 4, "layout": "2x2", "size": 160, "spacing": 180},
    "total_keepout": {
      "w": 1120,
      "h": 1120,
      "note": "= NWell extent (governing dimension). pSD clearance is within NWell envelope."
    },
    "m1_keepout": {
      "w": 1000,
      "h": 1000,
      "note": "M1 pad 640 + 2*M1_b(180) = 1000nm. Other M1 shapes must be >= 180nm from tie M1."
    },
    "nbulay_safe": true,
    "nbulay_note": "NWell 1120nm < 2990nm threshold. If NWell is bridged to adjacent device NWell, check combined width."
  },
  "ptap": {
