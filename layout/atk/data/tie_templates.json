      "step3_activ_2cont": "2*Cnt_a + Cnt_b + 2*Cnt_c = 2*160 + 180 + 2*70 = 640nm (2 contacts in a row)",
      "step4_chosen_activ": "640nm x 640nm (2x2 contact array for reliability)",
      "step5_nwell": "Activ + 2*NW_e = 640 + 2*240 = 1120nm",
      "step6_nwell_check": "1120nm < 2990nm nBuLay threshold => NO nBuLay generated (CRITICAL)",
      "step7_m1_pad": "Cnt_a + 2*M1_c = 160 + 0 = 160nm min, use 640nm for 2x2 contacts",
