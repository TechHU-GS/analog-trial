  "ntap": {
    "description": "Minimum NWell tie: N+ Activ in NWell, contacted to M1",
    "purpose": "Connects NWell to VDD to prevent latchup (LU.a)",
    "derivation": {
      "step1_contact": "Cnt_a=160nm square contact",
