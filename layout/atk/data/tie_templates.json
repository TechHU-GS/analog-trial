      "step1_contact": "Same as ntap: 2x2 array in 640nm activ",
      "step2_psd": "Activ + 2*pSD_d = 640 + 2*180 = 1000nm (pSD enclosure of activ for P-tap)",
      "step3_activ_space": "Act_b=210nm from any other activ",
      "step4_m1_pad": "640nm (same as ntap)"
    },
    "activ": {"w": 640, "h": 640},
    "psd": {"w": 1000, "h": 1000},
    "m1_pad": {"w": 640, "h": 640},
    "contacts": {"count": 4, "layout": "2x2", "size": 160, "spacing": 180},
    "total_keepout": {
      "w": 1000,
      "h": 1000,
      "note": "= pSD extent (governing dimension for substrate tie)"
    },
    "m1_keepout": {
      "w": 1000,
      "h": 1000,
      "note": "M1 pad 640 + 2*M1_b(180) = 1000nm"
    }
  },
  "placement_rules": {
    "ntap_to_pmos_pactiv_max_distance_nm": 20000,
